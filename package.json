{
	"name": "terminal-gui",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"prepare": "husky",
		"dev": "bash scripts/electrobun.sh dev",
		"build:native": "bash scripts/build-native.sh",
		"build:renderer": "bun scripts/build-renderer.ts",
		"build": "bun run build:renderer && bun run build:native && bash scripts/electrobun.sh build",
		"start": "bash scripts/electrobun.sh run",
		"release": "bun scripts/release.ts",
		"release:resume": "bun scripts/release.ts --resume",
		"format": "bunx biome format --write ./src",
		"format:prettier": "prettier . --write",
		"check": "bunx biome check --write ./src"
	},
	"lint-staged": {
		"*": "prettier --write --ignore-unknown"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@stylexjs/unplugin": "^0.18.3",
		"@tailwindcss/cli": "^4.3.0",
		"@types/bun": "latest",
		"@types/jsdom": "^28.0.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"create-dmg": "^8.1.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"unplugin": "^2.3.11"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.2",
		"@stylexjs/stylex": "^0.18.3",
		"@tanstack/react-virtual": "^3.13.26",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"electrobun": "^1.18.1",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-router-dom": "^7.15.0",
		"shiki": "^4.0.2",
		"tailwindcss": "^4.3.0",
		"yaml": "^2.9.0"
	}
}
