---
import Inferay from "../components/Inferay";
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/app-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="Inferay is a desktop shell for agent chats, terminals, file context, diffs, and repo workspaces."
		/>
		<title>inferay</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="site-grid-bg min-h-screen overflow-x-hidden bg-black font-sans text-white antialiased"
	>
		<header class="fixed left-0 right-0 top-0 z-50 px-4 py-4">
			<nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
				<div class="flex items-center gap-3">
					<div class="relative">
						<div class="absolute -inset-1 rounded-xl bg-white/10 blur-md"></div>
						<img
							src="/app-icon.png"
							alt="inferay"
							class="relative h-10 w-10 rounded-xl object-cover shadow-lg"
						/>
					</div>
					<span class="text-[16px] font-semibold tracking-normal">inferay</span>
				</div>
			</nav>
		</header>

		<main class="relative">
			<section class="px-2 pb-8 pt-32 sm:px-4">
				<div class="mx-auto mb-10 max-w-3xl text-center">
					<h1
						class="mb-5 text-6xl font-bold leading-[1.05] tracking-normal text-white drop-shadow-lg sm:text-7xl"
					>
						inferay
					</h1>
					<p class="mx-auto mb-8 max-w-lg text-[17px] leading-relaxed text-white/60">
						Run agent chats, terminals, file context, diffs, and repo workspaces
						in one desktop shell.
					</p>

					<div class="mx-auto max-w-xl">
						<div
							class="overflow-hidden rounded-lg border border-white/10 bg-[#0d0d0d] text-left shadow-2xl shadow-black/40"
						>
							<div class="flex h-9 items-center border-b border-white/10 px-3">
								<span class="text-[12px] font-medium text-white/55">
									Terminal
								</span>
								<span class="flex-1"></span>
								<button
									id="copy-install-command"
									type="button"
									class="rounded-md border border-white/10 bg-white/[0.06] px-2.5 py-1 text-[12px] font-medium text-white/75 hover:bg-white/[0.1] hover:text-white"
								>
									Copy
								</button>
							</div>
							<div class="flex items-center gap-2 px-4 py-3 font-mono text-[15px]">
								<span class="select-none text-white/35">$</span>
								<code id="install-command" class="text-white">npx inferay</code>
							</div>
						</div>
						<p
							id="copy-install-feedback"
							class="mt-3 text-center text-[13px] text-white/40"
						>
							Install or launch from your terminal.
						</p>
					</div>
					<script>
						document
							.getElementById("copy-install-command")
							?.addEventListener("click", async function () {
								const command =
									document
										.getElementById("install-command")
										?.textContent?.trim() || "npx inferay";
								const feedback = document.getElementById(
									"copy-install-feedback"
								);
								try {
									await navigator.clipboard.writeText(command);
									if (feedback) {
										feedback.textContent =
											"Copied. Paste it into your terminal.";
									}
								} catch {
									if (feedback) feedback.textContent = command;
								}
							});
					</script>
				</div>

				<div class="mx-auto w-full max-w-7xl">
					<Inferay client:visible />
				</div>
			</section>
		</main>

		<footer class="px-6 py-8">
			<div class="mx-auto flex max-w-6xl items-center justify-center">
				<p class="text-xs text-white/30">&copy; 2026 inferay</p>
			</div>
		</footer>
	</body>
</html>
